# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# IMPORTANT: Replace this with your actual database URL before running migrations
# For local development (you need PostgreSQL installed):
DATABASE_URL="postgresql://postgres:password@localhost:5432/matrimonial?schema=public"

# For Vercel Postgres (recommended for production):
# 1. Go to your Vercel project → Storage → Create Database → Postgres
# 2. Copy the DATABASE_URL from Vercel and paste it here
# DATABASE_URL="postgres://default:xxxxx@xxxx-pooler.us-east-1.postgres.vercel-storage.com/verceldb?sslmode=require"